#!/bin/bash
# tmux-chrome — CLI for tmux ↔ Chrome tab group bridge
# Communicates with bridge.py via Unix socket at /tmp/tmux-chrome-bridge.sock

set -eo pipefail

CHROME_BRIDGE_SOCKET="/tmp/tmux-chrome-bridge.sock"

function chrome_cmd {
  local json="$1"

  if [[ ! -S "$CHROME_BRIDGE_SOCKET" ]]; then
    echo "Error: Chrome bridge not running (socket not found)" >&2
    return 1
  fi

  python3 -c "
import socket, sys, json
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(5)
try:
    s.connect('$CHROME_BRIDGE_SOCKET')
    s.sendall(('''$json''' + '\n').encode())
    data = b''
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        data += chunk
        if b'\n' in data:
            break
    print(data.decode().strip())
except Exception as e:
    print(json.dumps({'success': False, 'error': str(e)}))
finally:
    s.close()
" 2>/dev/null
}

function request_id {
  echo "req_$(date +%s%N | cut -c1-13)"
}

function json_escape {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().rstrip("\n"), ensure_ascii=False))'
}

CHROME_EXTENSION_ID="${TMUX_CHROME_EXT_ID:-dplackkpcodnphbdcmfppmcbhkonlecg}"

WORKING_PREFIX="⏳"
DONE_PREFIX="🟢"

function debug_log {
  [[ "${TMUX_CHROME_DEBUG:-0}" == "1" ]] || return 0
  echo "[tmux-chrome] $*" >&2
}

function normalize_window_title {
  local title="$1"
  title="${title#${WORKING_PREFIX}}"
  title="${title#${DONE_PREFIX}}"
  title="${title# }"
  python3 -c '
import re, sys, unicodedata
s = sys.argv[1]
s = unicodedata.normalize("NFKC", s).lower()
s = re.sub(r"[^a-z0-9]+", "", s)
print(s)
' "$title"
}

function should_use_current_mapping_for_title {
  local requested="$1"
  local current
  current=$(tmux_current_window_title)
  [[ -n "$requested" && "$requested" == "$current" ]]
}

function tmux_get_group_title {
  tmux show-option -qvw @chrome_group 2>/dev/null || true
}

function tmux_get_group_id {
  tmux show-option -qvw @chrome_group_id 2>/dev/null || true
}

function tmux_get_group_window_id {
  tmux show-option -qvw @chrome_window_id 2>/dev/null || true
}

function tmux_set_group_mapping {
  local title="$1"
  local group_id="$2"
  local window_id="$3"
  tmux set-option -qw @chrome_group "$title" 2>/dev/null || true
  [[ -n "$group_id" ]] && tmux set-option -qw @chrome_group_id "$group_id" 2>/dev/null || true
  [[ -n "$window_id" ]] && tmux set-option -qw @chrome_window_id "$window_id" 2>/dev/null || true
  debug_log "mapping set title='$title' group_id='${group_id:-}' window_id='${window_id:-}'"
}

function tmux_clear_group_mapping {
  tmux set-option -quw @chrome_group 2>/dev/null || true
  tmux set-option -quw @chrome_group_id 2>/dev/null || true
  tmux set-option -quw @chrome_window_id 2>/dev/null || true
  debug_log "mapping cleared"
}

function tmux_current_window_title {
  local raw
  raw=$(tmux display-message -p '#W' 2>/dev/null || true)
  normalize_window_title "$raw"
}

function build_group_locator_json {
  local title="$1"
  local group_id="$2"
  local window_id="$3"
  local parts=()
  if [[ -n "$title" ]]; then
    parts+=("\"name\":$(printf '%s' "$title" | json_escape)")
  fi
  if [[ -n "$group_id" && "$group_id" =~ ^[0-9-]+$ ]]; then
    parts+=("\"group_id\":$group_id")
  fi
  if [[ -n "$window_id" && "$window_id" =~ ^[0-9-]+$ ]]; then
    parts+=("\"window_id\":$window_id")
  fi
  local joined=""
  local first=1
  for p in "${parts[@]}"; do
    if [[ $first -eq 1 ]]; then
      joined="$p"
      first=0
    else
      joined="$joined,$p"
    fi
  done
  printf '{%s}' "$joined"
}

function current_frontmost_app {
  osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true' 2>/dev/null || true
}

function ax_window_geometry {
  /Users/gavin.jeong/.local/bin/ax-window-geometry "$@"
}

function is_known_terminal_app {
  local app="$1"
  case "$app" in
    Ghostty|Alacritty|kitty|iTerm2|Terminal|WezTerm|Warp)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

function terminal_app_from_command {
  local command="$1"
  case "$command" in
    *"/Ghostty.app/"*|*/ghostty|ghostty)
      printf '%s\n' "Ghostty"
      ;;
    *"/Alacritty.app/"*|*/alacritty|alacritty)
      printf '%s\n' "Alacritty"
      ;;
    *"/kitty.app/"*|*/kitty|kitty)
      printf '%s\n' "kitty"
      ;;
    *"/iTerm.app/"*|*"/iTerm2.app/"*|*/iTerm2|iTerm2)
      printf '%s\n' "iTerm2"
      ;;
    *"/Terminal.app/"*|*/Terminal|Terminal)
      printf '%s\n' "Terminal"
      ;;
    *"/WezTerm.app/"*|*/wezterm-gui|wezterm-gui|WezTerm)
      printf '%s\n' "WezTerm"
      ;;
    *"/Warp.app/"*|*/warp|warp|WarpTerminal)
      printf '%s\n' "Warp"
      ;;
    *)
      return 1
      ;;
  esac
}

function detect_tmux_terminal_app {
  local client_pid
  client_pid=$(tmux display-message -p '#{client_pid}' 2>/dev/null || true)

  if [[ "$client_pid" =~ ^[0-9]+$ ]]; then
    local pid="$client_pid"
    local depth=0

    while [[ "$pid" =~ ^[0-9]+$ ]] && (( pid > 1 )) && (( depth < 20 )); do
      local row
      row=$(ps -o ppid=,args= -p "$pid" 2>/dev/null | sed 's/^[[:space:]]*//')
      [[ -z "$row" ]] && break

      local ppid="${row%% *}"
      local args="${row#"$ppid"}"
      args="${args# }"

      local app
      app=$(terminal_app_from_command "$args" 2>/dev/null || true)
      if [[ -n "$app" ]]; then
        printf '%s\n' "$app"
        return 0
      fi

      pid="$ppid"
      ((depth++))
    done
  fi

  local frontmost_app
  frontmost_app=$(current_frontmost_app)
  if is_known_terminal_app "$frontmost_app"; then
    printf '%s\n' "$frontmost_app"
    return 0
  fi

  echo "Error: could not determine terminal app for current tmux client" >&2
  return 1
}

function cmd_reload {
  echo "Reloading extension..."

  # Navigate to extension's reload.html which calls chrome.runtime.reload()
  osascript -e "
    tell application \"Google Chrome\"
      open location \"chrome-extension://$CHROME_EXTENSION_ID/reload.html\"
    end tell
  " 2>/dev/null

  # Wait for socket to come back
  local tries=0
  while [[ ! -S "$CHROME_BRIDGE_SOCKET" ]] && [[ $tries -lt 15 ]]; do
    sleep 0.5
    ((tries++))
  done

  if [[ -S "$CHROME_BRIDGE_SOCKET" ]]; then
    echo "Bridge reconnected"
  else
    echo "Error: Bridge did not reconnect" >&2
    return 1
  fi
}

function cmd_switch {
  local window_name="${1:-$(tmux_current_window_title)}"
  local group_id window_id
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  tmux set-option -qw @chrome_group "$window_name" 2>/dev/null
  [[ -S "$CHROME_BRIDGE_SOCKET" ]] || return 0
  local id response locator
  id=$(request_id)
  locator=$(build_group_locator_json "$window_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"switch_window\",\"window_name\":$(printf '%s' "$window_name" | json_escape),\"locator\":${locator},\"id\":\"$id\"}" 2>/dev/null || true)
  if [[ -n "$response" ]]; then
    local success
    success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
    if [[ "$success" == "true" ]]; then
      local resolved_group_id resolved_window_id resolved_title
      resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
      resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
      resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
      tmux_set_group_mapping "${resolved_title:-$window_name}" "$resolved_group_id" "$resolved_window_id"
    fi
  fi
}

function cmd_rename {
  local old_name new_name group_id window_id
  old_name=$(normalize_window_title "$(tmux_get_group_title)")
  new_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)

  tmux set-option -qw @chrome_group "$new_name" 2>/dev/null

  if [[ -z "$old_name" || "$old_name" == "$new_name" ]]; then
    return 0
  fi

  [[ -S "$CHROME_BRIDGE_SOCKET" ]] || return 0
  local id response locator
  id=$(request_id)
  locator=$(build_group_locator_json "$old_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"rename_group\",\"old_name\":$(printf '%s' "$old_name" | json_escape),\"new_name\":$(printf '%s' "$new_name" | json_escape),\"locator\":${locator},\"id\":\"$id\"}" 2>/dev/null || true)
  if [[ -n "$response" ]]; then
    local success
    success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
    if [[ "$success" == "true" ]]; then
      local resolved_group_id resolved_window_id resolved_title
      resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
      resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
      resolved_title=$(echo "$response" | jq -r '.data.new_name // empty' 2>/dev/null)
      tmux_set_group_mapping "${resolved_title:-$new_name}" "$resolved_group_id" "$resolved_window_id"
    fi
  fi
}

function cmd_list {
  local id
  id=$(request_id)
  local response
  response=$(chrome_cmd "{\"type\":\"list_groups\",\"id\":\"$id\"}")

  if [[ -z "$response" ]]; then
    echo "No response from Chrome bridge" >&2
    return 1
  fi

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi

  echo "$response" | jq -r '.data[] | "\(.title)\t\(.tab_count) tabs\t\(if .collapsed then "collapsed" else "expanded" end)"' | column -t -s $'\t'
}

function cmd_delete {
  local group_name="${1:-$(tmux_current_window_title)}"
  local group_id window_id id response locator
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"delete_group\",\"name\":$(printf '%s' "$group_name" | json_escape),\"locator\":${locator},\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" == "true" ]]; then
    tmux_clear_group_mapping
    echo "Deleted tab group: $group_name"
  else
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_focus {
  local app="${1:-chrome}"
  case "$app" in
    chrome)  osascript -e 'tell application "Google Chrome" to activate' 2>/dev/null ;;
    discord)  osascript -e 'tell application "Discord" to activate' 2>/dev/null ;;
    zoom)  osascript -e 'tell application "Zoom" to activate' 2>/dev/null ;;
    slack)   osascript -e 'tell application "Slack" to activate' 2>/dev/null ;;
    *)       osascript -e "tell application \"$app\" to activate" 2>/dev/null ;;
  esac
}

function cmd_open {
  local url="$1"
  if [[ -z "$url" ]]; then
    echo "Usage: tmux-chrome open <url>" >&2
    return 1
  fi

  local group_name group_id window_id id response locator
  group_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"add_tab\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"url\":$(printf '%s' "$url" | json_escape),\"active\":true,\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" == "true" ]]; then
    local resolved_group_id resolved_window_id resolved_title
    resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
    resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
    resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
    tmux_set_group_mapping "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id"
    echo "Opened in '${resolved_title:-$group_name}': $url"
    cmd_focus chrome >/dev/null 2>&1 || true
  else
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_add {
  local url="$1"
  if [[ -z "$url" ]]; then
    echo "Usage: tmux-chrome add <url>" >&2
    return 1
  fi
  local group_name group_id window_id id response locator
  group_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"add_tab\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"url\":$(printf '%s' "$url" | json_escape),\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" == "true" ]]; then
    local created resolved_group_id resolved_window_id resolved_title
    created=$(echo "$response" | jq -r '.data.created_group // false')
    resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
    resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
    resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
    tmux_set_group_mapping "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id"
    if [[ "$created" == "true" ]]; then
      echo "Created group '${resolved_title:-$group_name}' and added tab: $url"
    else
      echo "Added tab to '${resolved_title:-$group_name}': $url"
    fi
  else
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_move {
  local group_name group_id window_id id response locator
  group_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"move_tab\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" == "true" ]]; then
    local resolved_group_id resolved_window_id resolved_title
    resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
    resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
    resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
    tmux_set_group_mapping "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id"
    echo "Moved active tab to group: ${resolved_title:-$group_name}"
  else
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_remove {
  local id
  id=$(request_id)
  local response
  response=$(chrome_cmd "{\"type\":\"remove_tab\",\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" == "true" ]]; then
    echo "Removed active tab from its group"
  else
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_export_group {
  local group_name="${1:-$(tmux_current_window_title 2>/dev/null)}"
  if [[ -z "$group_name" ]]; then
    echo "Usage: tmux-chrome export-group <group_name>" >&2
    return 1
  fi

  local group_id="" window_id="" id response locator
  if [[ -z "$1" ]] || should_use_current_mapping_for_title "$group_name"; then
    group_id=$(tmux_get_group_id)
    window_id=$(tmux_get_group_window_id)
  fi
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"get_tabs\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"id\":\"$id\"}" 2>/dev/null)

  local success
  success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
  if [[ "$success" != "true" ]]; then
    echo "{}"
    return 0
  fi

  echo "$response" | jq -c --arg group "$group_name" '{group: $group, tabs: [.data[] | {url, title}]}'
}

function cmd_clear_group {
  local group_name="${1:-$(tmux_current_window_title 2>/dev/null)}"
  if [[ -z "$group_name" ]]; then
    echo "Usage: tmux-chrome clear-group <group_name>" >&2
    return 1
  fi

  local group_id="" window_id="" id response locator
  if [[ -z "$1" ]] || should_use_current_mapping_for_title "$group_name"; then
    group_id=$(tmux_get_group_id)
    window_id=$(tmux_get_group_window_id)
  fi
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  response=$(chrome_cmd "{\"type\":\"delete_group\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"id\":\"$id\"}" 2>/dev/null) || true
  local success
  success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
  if [[ "$success" == "true" ]]; then
    if [[ -z "$1" ]] || should_use_current_mapping_for_title "$group_name"; then
      tmux_clear_group_mapping
    fi
    echo "Cleared group: $group_name"
  else
    echo "Group missing or already clear: $group_name" >&2
  fi
}

function cmd_import_group {
  local group_name="$1"
  local source="${2:--}"
  if [[ -z "$group_name" ]]; then
    echo "Usage: tmux-chrome import-group <group_name> [json-file|-]" >&2
    return 1
  fi

  local payload
  if [[ "$source" == "-" ]]; then
    payload=$(cat)
  else
    payload=$(cat "$source")
  fi

  [[ -z "$payload" ]] && return 0

  cmd_clear_group "$group_name" >/dev/null 2>&1 || true

  local group_json created=0
  local update_current_mapping=0
  if should_use_current_mapping_for_title "$group_name"; then
    update_current_mapping=1
  fi
  group_json=$(printf '%s' "$group_name" | json_escape)
  echo "$payload" | jq -r '.tabs[]?.url' | while IFS= read -r url; do
    [[ -z "$url" ]] && continue
    local id url_json response
    id=$(request_id)
    url_json=$(printf '%s' "$url" | json_escape)
    response=$(chrome_cmd "{\"type\":\"add_tab\",\"name\":${group_json},\"url\":${url_json},\"active\":false,\"id\":\"$id\"}" 2>/dev/null || true)
    if [[ $created -eq 0 && -n "$response" ]]; then
      local success
      success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
      if [[ "$success" == "true" ]]; then
        local resolved_group_id resolved_window_id resolved_title
        resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
        resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
        resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
        if [[ "$update_current_mapping" -eq 1 ]]; then
          tmux_set_group_mapping "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id"
        fi
        created=1
      fi
    fi
  done
}

function cmd_grab {
  local group_name group_id window_id
  group_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)
  local window_index
  window_index=$(tmux display-message -p '#{window_index}')

  local extracted
  extracted=$(
    for pane_index in $(tmux list-panes -t ":${window_index}" -F '#{pane_index}'); do
      tmux capture-pane -p -t ":${window_index}.${pane_index}" -S -500 2>/dev/null
    done | grep -oE 'https?://[A-Za-z0-9._~:/?#@!$&()*+,;=%[-]+' | sed 's/[.,;:!)]*$//' | sort -u
  )

  if [[ -z "$extracted" ]]; then
    echo "No URLs found in current window panes" >&2
    return 1
  fi

  local selected
  selected=$(echo "$extracted" | fzf \
    --multi \
    --header="Select URLs to add to tab group '$group_name' (Tab to multi-select)" \
    --preview='echo {}' \
    --preview-window=down:1:wrap)

  if [[ -z "$selected" ]]; then
    return 0
  fi

  local count=0 total
  total=$(echo "$selected" | grep -c .)
  local locator
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
  while IFS= read -r url; do
    if [[ -n "$url" ]]; then
      local id active response
      id=$(request_id)
      ((count++))
      active="false"
      if [[ "$count" -eq "$total" ]]; then
        active="true"
      fi
      response=$(chrome_cmd "{\"type\":\"add_tab\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"url\":$(printf '%s' "$url" | json_escape),\"active\":${active},\"id\":\"$id\"}" 2>/dev/null || true)
      if [[ -n "$response" ]]; then
        local success
        success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
        if [[ "$success" == "true" ]]; then
          local resolved_group_id resolved_window_id resolved_title
          resolved_group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
          resolved_window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
          resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
          tmux_set_group_mapping "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id"
          locator=$(build_group_locator_json "${resolved_title:-$group_name}" "$resolved_group_id" "$resolved_window_id")
        fi
      fi
    fi
  done <<< "$selected"

  echo "Added $count tab(s) to group '$group_name'"
  if [[ "$count" -gt 0 ]]; then
    cmd_focus chrome >/dev/null 2>&1 || true
  fi
}

function cmd_tabs {
  local all_flag=""
  local group_name group_id window_id
  group_name=$(tmux_current_window_title)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)

  if [[ "$1" == "--all" ]]; then
    all_flag="true"
  fi

  local id response locator
  id=$(request_id)
  locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")

  if [[ -n "$all_flag" ]]; then
    response=$(chrome_cmd "{\"type\":\"get_tabs\",\"all\":true,\"id\":\"$id\"}")
  else
    response=$(chrome_cmd "{\"type\":\"get_tabs\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"id\":\"$id\"}")
  fi

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi

  local tab_count
  tab_count=$(echo "$response" | jq '.data | length')
  if [[ "$tab_count" == "0" ]]; then
    echo "No tabs found" >&2
    return 1
  fi

  local fzf_input
  fzf_input=$(echo "$response" | jq -r '.data[] | "\(.id)\t[\(.group_title)] \(.title)\t\(.url)"')

  local selected
  selected=$(echo "$fzf_input" | fzf \
    --header="Select a tab to focus (terminal stays focused)" \
    --delimiter=$'\t' \
    --with-nth='2,3' \
    --preview='echo {3}' \
    --preview-window=down:1:wrap)

  if [[ -z "$selected" ]]; then
    return 0
  fi

  local tab_id focus_id
  tab_id=$(echo "$selected" | cut -f1)
  focus_id=$(request_id)
  chrome_cmd "{\"type\":\"focus_tab\",\"tab_id\":$tab_id,\"id\":\"$focus_id\"}" > /dev/null
  echo "Focused tab: $(echo "$selected" | cut -f2)"
}

function cmd_sync {
  local tmux_windows
  tmux_windows=$(tmux list-windows -F '#{window_name}' 2>/dev/null | while IFS= read -r w; do normalize_window_title "$w"; done)
  if [[ -z "$tmux_windows" ]]; then
    echo "Error: not in a tmux session" >&2
    return 1
  fi

  local id response
  id=$(request_id)
  response=$(chrome_cmd "{\"type\":\"list_groups\",\"id\":\"$id\"}")

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi

  local removed=0
  while IFS= read -r group_title; do
    [[ -z "$group_title" ]] && continue
    if ! echo "$tmux_windows" | grep -qxF "$group_title"; then
      if [[ "$group_title" == "native" ]]; then
        continue
      fi
      local del_id
      del_id=$(request_id)
      chrome_cmd "{\"type\":\"delete_group\",\"name\":$(printf '%s' "$group_title" | json_escape),\"id\":\"$del_id\"}" > /dev/null 2>&1
      echo "Removed orphan group: $group_title"
      ((removed++))
    fi
  done < <(echo "$response" | jq -r '.data[].title')

  if [[ $removed -eq 0 ]]; then
    echo "No orphan tab groups found"
  else
    echo "Removed $removed orphan group(s)"
  fi
}

function cmd_rebind_current_window {
  local group_name id response success
  group_name=$(tmux_current_window_title)
  id=$(request_id)
  response=$(chrome_cmd "{\"type\":\"pick_rebind_group\",\"id\":\"$id\"}")
  success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
  local group_id window_id resolved_title source
  group_id=$(echo "$response" | jq -r '.data.group_id // empty' 2>/dev/null)
  window_id=$(echo "$response" | jq -r '.data.window_id // empty' 2>/dev/null)
  resolved_title=$(echo "$response" | jq -r '.data.group_title // empty' 2>/dev/null)
  source=$(echo "$response" | jq -r '.data.source // empty' 2>/dev/null)
  if [[ -z "$group_id" ]]; then
    echo "Error: no Chrome tab group available to bind" >&2
    return 1
  fi
  tmux_set_group_mapping "$group_name" "$group_id" "$window_id"
  echo "Rebound tmux window '$group_name' to Chrome group '${resolved_title:-$group_name}' (group_id=$group_id, source=$source)"
}

function cmd_picker {
  # Unified fzf picker: apps + current window's tab group tabs
  local apps="app\t[app] Chrome\napp\t[app] Slack\napp\t[app] Zoom\napp\t[app] Discord"
  local tabs_section=""
  local group_name group_id window_id
  group_name=$(tmux_current_window_title 2>/dev/null)
  group_id=$(tmux_get_group_id)
  window_id=$(tmux_get_group_window_id)

  if [[ -S "$CHROME_BRIDGE_SOCKET" ]] && [[ -n "$group_name" ]]; then
    local id response locator
    id=$(request_id)
    locator=$(build_group_locator_json "$group_name" "$group_id" "$window_id")
    response=$(chrome_cmd "{\"type\":\"get_tabs\",\"locator\":${locator},\"name\":$(printf '%s' "$group_name" | json_escape),\"id\":\"$id\"}" 2>/dev/null)
    local success
    success=$(echo "$response" | jq -r '.success // false' 2>/dev/null)
    if [[ "$success" == "true" ]]; then
      tabs_section=$(echo "$response" | jq -r '.data[] | "tab:\(.id)\t[tab] \(.title)  \(.url)"')
    fi
  fi

  local fzf_input
  fzf_input=$(printf "%b" "$apps")
  if [[ -n "$tabs_section" ]]; then
    fzf_input="$fzf_input"$'\n'"$tabs_section"
  fi

  local selected
  selected=$(echo "$fzf_input" | fzf \
    --prompt="focus> " \
    --delimiter=$'\t' \
    --with-nth=2 \
    --preview='echo {2}' \
    --preview-window=down:1:wrap)

  [[ -z "$selected" ]] && return 0

  local type_field
  type_field=$(echo "$selected" | cut -f1)

  case "$type_field" in
    app)
      local app_name
      app_name=$(echo "$selected" | cut -f2 | sed 's/^\[app\] //')
      cmd_focus "$app_name"
      ;;
    tab:*)
      local tab_id="${type_field#tab:}"
      local focus_id
      focus_id=$(request_id)
      chrome_cmd "{\"type\":\"focus_tab\",\"tab_id\":$tab_id,\"id\":\"$focus_id\"}" > /dev/null
      ;;
  esac
}

function cmd_clean {
  local id
  id=$(request_id)
  local response
  response=$(chrome_cmd "{\"type\":\"clean_tabs\",\"id\":\"$id\"}")

  if [[ -z "$response" ]]; then
    echo "No response from Chrome bridge" >&2
    return 1
  fi

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi

  local moved group
  moved=$(echo "$response" | jq -r '.data.moved // 0')
  group=$(echo "$response" | jq -r '.data.group // "native"')
  if [[ "$moved" == "0" ]]; then
    echo "No ungrouped tabs to clean."
  else
    echo "Moved $moved ungrouped tab(s) into '$group' group."
  fi
}

function cmd_merge {
  local id
  id=$(request_id)
  local response
  response=$(chrome_cmd "{\"type\":\"merge_windows\",\"id\":\"$id\"}")

  if [[ -z "$response" ]]; then
    echo "No response from Chrome bridge" >&2
    return 1
  fi

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi

  local merged moved groups target
  merged=$(echo "$response" | jq -r '.data.windows_merged // 0')
  moved=$(echo "$response" | jq -r '.data.moved_tabs // 0')
  groups=$(echo "$response" | jq -r '.data.merged_groups // 0')
  target=$(echo "$response" | jq -r '.data.target_window_id // "?"')

  if [[ "$merged" == "0" ]]; then
    echo "Only one Chrome window — nothing to merge."
  else
    echo "Merged $merged window(s) into window $target: $moved tab(s), $groups new group(s) moved."
  fi
}

function cmd_cycle_tab {
  local direction="${1:-next}"
  case "$direction" in
    prev|next) ;;
    *)
      echo "Usage: tmux-chrome cycle-tab {prev|next}" >&2
      return 1
      ;;
  esac

  local id
  id=$(request_id)
  local response
  response=$(chrome_cmd "{\"type\":\"cycle_tab_in_group\",\"direction\":\"${direction}\",\"id\":\"$id\"}")

  if [[ -z "$response" ]]; then
    echo "No response from Chrome bridge" >&2
    return 1
  fi

  local success
  success=$(echo "$response" | jq -r '.success // false')
  if [[ "$success" != "true" ]]; then
    echo "Error: $(echo "$response" | jq -r '.error // "unknown"')" >&2
    return 1
  fi
}

function cmd_swap_window {
  local terminal_app
  terminal_app=$(detect_tmux_terminal_app) || return 1

  local previous_app
  previous_app=$(current_frontmost_app)

  local terminal_geometry
  terminal_geometry=$(ax_window_geometry "$terminal_app" get) || {
    echo "Error: failed to read geometry for $terminal_app" >&2
    return 1
  }

  local terminal_x terminal_y terminal_width terminal_height
  IFS=$'\t' read -r terminal_x terminal_y terminal_width terminal_height <<< "$terminal_geometry"

  local chrome_bounds
  chrome_bounds=$(osascript <<'APPLESCRIPT'
tell application "Google Chrome"
  if (count of windows) is 0 then
    error "No window found for Google Chrome"
  end if
  set b to bounds of front window
  return (item 1 of b as text) & "|" & (item 2 of b as text) & "|" & ((item 3 of b) - (item 1 of b) as text) & "|" & ((item 4 of b) - (item 2 of b) as text)
end tell
APPLESCRIPT
) || {
    echo "Error: failed to read geometry for Google Chrome" >&2
    return 1
  }

  local chrome_x chrome_y chrome_width chrome_height
  IFS='|' read -r chrome_x chrome_y chrome_width chrome_height <<< "$chrome_bounds"

  ax_window_geometry "$terminal_app" set "$chrome_x" "$chrome_y" "$chrome_width" "$chrome_height" >/dev/null || {
    echo "Error: failed to move $terminal_app window" >&2
    return 1
  }

  osascript <<APPLESCRIPT >/dev/null
 tell application "Google Chrome"
   set bounds of front window to {$terminal_x, $terminal_y, $((terminal_x + terminal_width)), $((terminal_y + terminal_height))}
 end tell
APPLESCRIPT

  tmux refresh-client -S >/dev/null 2>&1 || true
  tmux refresh-client -C ${chrome_width}x${chrome_height} >/dev/null 2>&1 || true

  if [[ -n "$previous_app" ]]; then
    cmd_focus "$previous_app" >/dev/null 2>&1 || true
  fi

  echo "Swapped window geometry: $terminal_app ↔ Google Chrome"
}


function main {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    switch)  cmd_switch "$@" ;;
    list)    cmd_list ;;
    delete)  cmd_delete "$@" ;;
    open)    cmd_open "$@" ;;
    focus)   cmd_focus "$@" ;;
    add)     cmd_add "$@" ;;
    move)    cmd_move ;;
    remove)  cmd_remove ;;
    export-group) cmd_export_group "$@" ;;
    import-group) cmd_import_group "$@" ;;
    clear-group) cmd_clear_group "$@" ;;
    grab)    cmd_grab ;;
    tabs)    cmd_tabs "$@" ;;
    rename)  cmd_rename ;;
    reload)  cmd_reload ;;
    clean)   cmd_clean ;;
    sync)    cmd_sync ;;
    merge)   cmd_merge ;;
    cycle-tab) cmd_cycle_tab "$@" ;;
    rebind-current-window) cmd_rebind_current_window ;;
    picker)  cmd_picker ;;
    swap-window) cmd_swap_window ;;
    *)
      echo "Usage: tmux-chrome {switch|list|delete|open|add|move|remove|export-group|import-group|clear-group|grab|tabs|rename|reload|focus|clean|sync|merge|cycle-tab|rebind-current-window|picker|swap-window}"
      echo ""
      echo "  switch          Switch to tab group matching current tmux window"
      echo "  rename          Rename tab group to match current tmux window name"
      echo "  list            List all tab groups"
      echo "  delete          Delete tab group for current window"
      echo "  focus [app]     Bring app to foreground (chrome, slack, or any app name)"
      echo "  open <url>      Open URL directly into current window's tab group"
      echo "  add <url>       Add URL to current window's tab group"
      echo "  move            Move Chrome's active tab to current window's group"
      echo "  remove          Remove Chrome's active tab from its group"
      echo "  export-group    Export one tab group as JSON"
      echo "  import-group    Import one tab group from JSON"
      echo "  clear-group     Delete one named tab group"
      echo "  grab            Extract URLs from panes → fzf → add to tab group"
      echo "  tabs [--all]    Browse tabs in group via fzf → focus selected"
      echo "  reload          Restart Chrome extension and reconnect bridge"
      echo "  clean           Close all tabs not belonging to any tab group"
      echo "  sync            Remove tab groups with no matching tmux window"
      echo "  merge           Merge all Chrome windows of this profile into one"
      echo "  cycle-tab {prev|next}  Cycle focus within the active tab group (wraps)"
      echo "  rebind-current-window  Rebind this tmux window to the active Chrome group"
      echo "  swap-window     Swap current tmux terminal window geometry with active Chrome window"
      return 1
      ;;
  esac
}

main "$@"
